{
  "name": "horizon-atomic-settlement",
  "version": "1.0.0",
  "description": "Blockchain-Based Atomic Trade Settlement Platform (Educational Prototype)",
  "main": "backend/server.js",
  "scripts": {
    "compile": "npx hardhat compile",
    "node": "npx hardhat node",
    "deploy": "npx hardhat run scripts/deploy.cjs --network localhost",
    "deploy:sepolia": "npx hardhat run scripts/deploy.cjs --network sepolia",
    "backend": "node backend/server.js"
  },
  "keywords": [
    "blockchain",
    "settlement",
    "DvP",
    "hardhat",
    "prototype"
  ],
  "author": "TechFlankers",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ethers": "^6.11.0",
    "express": "^4.18.3"
  }
}
