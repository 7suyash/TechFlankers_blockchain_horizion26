# =================================================================
# Quickaro Atomic Settlement Platform - Environment Configuration
# =================================================================

# 1. Sepolia RPC URL (Get this from Alchemy, Infura, or QuickNode)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE"

# 2. Private Keys for your 3 testing accounts
# Remember to prefix with "0x" and NEVER share these!
# They should hold some testnet Sepolia ETH (from a faucet).

# Deployer/Admin Account
DEPLOYER_PRIVATE_KEY="0x_YOUR_DEPLOYER_PRIVATE_KEY_HERE"

# Buyer Account
BUYER_PRIVATE_KEY="0x_YOUR_BUYER_PRIVATE_KEY_HERE"

# Seller Account 
SELLER_PRIVATE_KEY="0x_YOUR_SELLER_PRIVATE_KEY_HERE"
